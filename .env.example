# ── Authentication & Security ────────────────────────────────────
# REQUIRED in production! Generate with:
#   openssl rand -hex 32
#   OR: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Dev: Will auto-generate if not set
JWT_SECRET=your-32-char-hex-string-here-min-32-chars

# Geräte-Zugangscode: wird einmal pro Tablet eingegeben (Seite /geraet-anmelden),
# danach für ~1 Jahr in einem Cookie gespeichert. Ohne diesen Code ist die App
# gar nicht erreichbar — auch nicht die Mitarbeiter-Namensauswahl.
# WICHTIG: Es gibt noch kein Rate-Limiting auf diesen Endpunkt — daher einen
# langen, zufälligen Code verwenden (KEINE 4-stellige PIN), z.B.:
#   node -e "console.log(require('crypto').randomBytes(12).toString('base64url'))"
# REQUIRED in production! Ohne gesetzten Wert schlägt die Geräte-Anmeldung in
# Produktion fehl (in Dev wird ein fester Test-Code verwendet, siehe Konsole).
DEVICE_ACCESS_CODE=your-long-random-device-code-here

# ── Google BigQuery ──────────────────────────────────────────────
# Empfohlen: GOOGLE_APPLICATION_CREDENTIALS (Application Default Credentials).
# Zeigt auf eine Service-Account-JSON-Datei, die NICHT im Repo liegt und
# NICHT als Klartext in einer Env-Var herumgereicht wird.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceaccount.json

# Fallback NUR für Deploys ohne Dateisystem-Zugriff (z. B. Vercel), bei denen
# GOOGLE_APPLICATION_CREDENTIALS nicht auf eine Datei zeigen kann:
# Den kompletten Service-Account-Key als Ein-Zeilen-JSON-String hinterlegen.
# WICHTIG:
#   - Niemals einen echten Key hier im Repo/PR einchecken oder in Chats teilen
#   - Nur über die Secret-Verwaltung des Hosting-Anbieters setzen (z.B. Vercel
#     Environment Variables), nie in .env.local committen
#   - Key regelmäßig rotieren (empfohlen: alle 90 Tage) und alte Keys in der
#     GCP Console widerrufen
# GCP_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"..."}

# BigQuery-Konfiguration (Defaults passen für ATLOS-Dataset)
BQ_PROJECT=zentrallager
BQ_DATASET=ATLOS
BQ_TABLE_ORDERS=atlos_orders
BQ_TABLE_CUSTOMERS=atlos_customers
BQ_TABLE_PRODUCTS=atlos_products
BQ_TABLE_INVOICE=atlos_invoice
BQ_TABLE_INVOICE_PRODUCTS=atlos_invoice_products
BQ_TABLE_RETOUREN=atlos_retouren
BQ_TABLE_RETOUREN_PRODUCTS=atlos_retouren_products
BQ_TABLE_GUTSCHRIFT=atlos_gutschrift
BQ_TABLE_GUTSCHRIFT_PRODUCTS=atlos_gutschrift_products

# TSHOS ist baugleich zu ATLOS (gleiches Tabellenschema, eigenes Dataset) und
# wird bei jeder Suche automatisch parallel mit ATLOS durchsucht. Defaults
# passen, wenn Dataset "TSHOS" und Tabellen mit Präfix "tshos_" heißen —
# ansonsten hier überschreiben. Schlägt die TSHOS-Abfrage fehl (z.B. Dataset
# noch nicht vorhanden/berechtigt), liefert ATLOS trotzdem normal Ergebnisse.
BQ_TSHOS_DATASET=TSHOS
BQ_TSHOS_TABLE_ORDERS=tshos_orders
BQ_TSHOS_TABLE_CUSTOMERS=tshos_customers
BQ_TSHOS_TABLE_PRODUCTS=tshos_products
BQ_TSHOS_TABLE_INVOICE=tshos_invoice
BQ_TSHOS_TABLE_INVOICE_PRODUCTS=tshos_invoice_products
BQ_TSHOS_TABLE_RETOUREN=tshos_retouren
BQ_TSHOS_TABLE_RETOUREN_PRODUCTS=tshos_retouren_products
BQ_TSHOS_TABLE_GUTSCHRIFT=tshos_gutschrift
BQ_TSHOS_TABLE_GUTSCHRIFT_PRODUCTS=tshos_gutschrift_products

# ── Asana ─────────────────────────────────────────────────────────
# Personal Access Token (Profil → My Settings → Apps → Developer console)
ASANA_TOKEN=your_asana_pat_here

# GID des Projekts "Retoureneingang" (aus der Asana-URL)
ASANA_PROJECT_GID=your_project_gid_here

# GID des Projekts "Versand" (aus der Asana-URL)
ASANA_VERSAND_PROJECT_GID=your_versand_project_gid_here

# GID des separaten Reklamations-Projekts (aus der Asana-URL). Wird nur
# verwendet, wenn mindestens ein Artikel in einer Retoure als "Reklamation"
# markiert wurde — dann legt die App dort automatisch einen zweiten Task mit
# angehängtem Reklamationsschein-PDF an (ersetzt den bisherigen manuellen
# WordPress-Ablauf). Ohne gesetzten Wert wird kein Reklamations-Task angelegt,
# die normale Retoure läuft trotzdem unbeeinflusst durch.
ASANA_REKLAMATION_PROJECT_GID=your_reklamation_project_gid_here

# GID des Tags "DHL Retoure" (Asana → Tag anklicken → GID aus der URL)
ASANA_DHL_TAG_GID=your_dhl_tag_gid_here

# GID des Tags "Amazon" in Asana (wird automatisch gesetzt bei Amazon-Bestellungen)
ASANA_AMAZON_TAG_GID=1205680122433653

# Optional: Abschnitt (Section) im Projekt "Retoureneingang" (ASANA_PROJECT_GID),
# in den unzustellbare Sendungen (Annahme verweigert/nicht abgeholt) einsortiert
# werden, damit sie nicht zwischen normalen Retouren stehen. GID findet man in
# Asana über Rechtsklick auf die Abschnitts-Überschrift → "Copy section link"
# (die Zahl am Ende der URL). Ohne gesetzten Wert landet die Aufgabe im
# Standard-Abschnitt des Projekts.
ASANA_UNZUSTELLBAR_SECTION_GID=your_section_gid_here

# Optional: GID eines Tags, mit dem unzustellbare Sendungen markiert werden
ASANA_UNZUSTELLBAR_TAG_GID=your_tag_gid_here
